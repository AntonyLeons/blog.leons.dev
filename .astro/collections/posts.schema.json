{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "layout": {
      "type": "string"
    },
    "current": {
      "type": "string"
    },
    "cover": {
      "type": "string"
    },
    "navigation": {
      "type": "boolean"
    },
    "title": {
      "type": "string"
    },
    "date": {
      "type": "string",
      "format": "date-time"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "class": {
      "type": "string"
    },
    "subclass": {
      "type": "string"
    },
    "author": {
      "type": "string"
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "date"
  ]
}