{
  "name": "blog.leons.dev",
  "version": "1.0.0",
  "description": "Personal blog",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "start": "concurrently \"npm run watch:css\" \"npm run serve:jekyll\"",
    "serve:jekyll": "bundle exec jekyll serve --livereload --incremental --open-url",
    "build": "npm run build:css && bundle exec jekyll build && npm run algolia",
    "algolia": "bundle exec jekyll algolia",
    "build:css": "postcss assets/css/*.css --dir assets/built --ext css",
    "watch:css": "postcss assets/css/*.css --dir assets/built --ext css --watch --verbose"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aleons/blog.leons.dev.git"
  },
  "author": "Leon",
  "license": "ISC",
  "devDependencies": {
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "cssnano": "^7.1.3",
    "postcss": "^8.5.8",
    "postcss-cli": "^11.0.1",
    "postcss-color-mod-function": "^4.1.1",
    "postcss-custom-properties": "^15.0.1",
    "postcss-import": "^16.1.1"
  },
  "config": {
    "posts_per_page": 25
  }
}
