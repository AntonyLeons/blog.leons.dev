---
import BaseHead from '../components/BaseHead.astro';
import SubscribeModal from '../components/SubscribeModal.astro';
import { SITE_CONFIG, getAssetUrl } from '../config';

// Import CSS stylesheets so Astro bundles them
import '../styles/global.css';
import '../styles/screen.css';
import '../styles/screen.edited.css';
import '../styles/syntax.css';

interface Props {
  title?: string;
  description?: string;
  image?: string | null;
  type?: 'website' | 'article';
  articleDate?: string | Date;
  tags?: string[];
  author?: string;
  current?: string;
}

const {
  title,
  description,
  image,
  type = 'website',
  articleDate,
  tags = [],
  author,
  current,
} = Astro.props;

const currentYear = new Date().getFullYear();
const bodyClass = current === 'home' ? 'home-template' : `${current || 'page'}-template`;
---

<!DOCTYPE html>
<html lang="en">
<head>
    <BaseHead
      title={title}
      description={description}
      image={image}
      type={type}
      articleDate={articleDate}
      tags={tags}
      author={author}
    />
</head>
<body class={bodyClass}>
    <div class="site-wrapper">
        <!-- Main Content Slot -->
        <slot />

        <!-- Footer -->
        <footer class="site-footer outer">
            <div class="site-footer-content inner">
                <section class="copyright">
                    <a href={getAssetUrl('/')}>{SITE_CONFIG.title}</a> &copy; {currentYear}
                </section>
                <section class="poweredby">
                    Proudly published with <a href="https://astro.build/" target="_blank" rel="noopener">Astro</a> using a modernized Casper theme
                </section>
                <nav class="site-footer-nav">
                    <a href={getAssetUrl('/')}>Latest Posts</a>
                    {SITE_CONFIG.facebook && (
                        <a href={`https://facebook.com/${SITE_CONFIG.facebook}`} target="_blank" rel="noopener">Facebook</a>
                    )}
                    {SITE_CONFIG.twitter && (
                        <a href={`https://twitter.com/${SITE_CONFIG.twitter}`} target="_blank" rel="noopener">Twitter</a>
                    )}
                    <a href="https://ghost.org" target="_blank" rel="noopener">Ghost</a>
                </nav>
            </div>
        </footer>
    </div>

    <!-- Subscribe Modal overlay -->
    {SITE_CONFIG.subscribers && <SubscribeModal />}
</body>
</html>
