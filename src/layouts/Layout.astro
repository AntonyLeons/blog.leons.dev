---
import { site } from '../data/config';

interface Props {
  title?: string;
  class?: string;
  description?: string;
  cover?: string;
}

const { title = site.title, class: className = "home-template" } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <title>{title}</title>
    <meta name="HandheldFriendly" content="True" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/favicon.ico" />
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    
    <link rel="stylesheet" type="text/css" href="/assets/built/screen.css" />
    <link rel="stylesheet" type="text/css" href="/assets/built/screen.edited.css" />
    <link rel="stylesheet" type="text/css" href="/assets/built/syntax.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/highlight.js@11/styles/github.min.css">
    
    <script is:inline src="//cdnjs.cloudflare.com/ajax/libs/highlight.js/11.5.1/highlight.min.js"></script>
    <script is:inline src="https://cdn.jsdelivr.net/npm/jquery@4.0.0/dist/jquery.min.js"></script>
    <script is:inline src="/assets/js/jquery.fitvids.js"></script>
</head>
<body class={className}>
    <div class="site-wrapper">
        <slot />

        <footer class="site-footer outer">
            <div class="site-footer-content inner">
                <section class="copyright"><a href="/">{site.title}</a> &copy; {new Date().getFullYear()}</section>
                <nav class="site-footer-nav">
                    <a href="/">Latest Posts</a>
                    <a href={`https://x.com/${site.x_username}`} target="_blank" rel="noopener">X</a>
                    <a href={site.github} target="_blank" rel="noopener">Github</a>
                </nav>
            </div>
        </footer>
    </div>
</body>
</html>
