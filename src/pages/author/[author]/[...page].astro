---
import { getCollection } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';
import SiteNav from '../../../components/SiteNav.astro';
import PostCard from '../../../components/PostCard.astro';
import { SITE_CONFIG, getAssetUrl } from '../../../config';
import authors from '../../../data/authors.json';

export async function getStaticPaths({ paginate }: any) {
  const allPosts = await getCollection('posts');
  const paths: any[] = [];
  
  for (const author of Object.keys(authors)) {
    const filteredPosts = allPosts.filter(post => post.data.author === author);
    filteredPosts.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
    
    const pages = paginate(filteredPosts, { 
      pageSize: SITE_CONFIG.pageSize,
      params: { author }
    });
    
    pages.forEach((p: any) => {
      console.log('DEBUG paginate p.params:', p.params, 'author:', author);
      paths.push({
        params: { 
          author, 
          page: p.params.page === 1 || p.params.page === '1' || !p.params.page ? undefined : `page${p.params.page}`
        },
        props: {
          pageProps: p.props,
          maxPages: pages.length
        }
      });
    });
  }
  
  return paths;
}

const { author } = Astro.params;
const { pageProps, maxPages } = Astro.props;
const { page } = pageProps;

// Resolve author
const authorKey = author as keyof typeof authors;
const authorData = authorKey in authors ? authors[authorKey] : null;

if (!authorData) {
  return Astro.redirect('/404.html');
}

const totalPosts = page.total;
const statsText = totalPosts === 0 ? 'No posts' : totalPosts === 1 ? '1 post' : `${totalPosts} posts`;

// Header backgrounds
const coverImage = authorData.cover ? getAssetUrl(authorData.cover) : null;
const authorProfileImg = authorData.picture ? getAssetUrl(authorData.picture) : null;
---

<Layout title={authorData.name} description={authorData.bio} image={coverImage} current="author">
    <!-- Header -->
    <header class={`site-header outer ${coverImage ? '' : 'no-cover'}`} style={coverImage ? `background-image: url(${coverImage})` : ''}>
        <div class="inner">
            <SiteNav current="author" />
            <div class="site-header-content">
                {authorProfileImg && (
                    <img class="author-profile-image" src={authorProfileImg} alt={authorData.name} />
                )}
                <h1 class="site-title">{authorData.name}</h1>
                {authorData.bio && (
                    <h2 class="author-bio">{authorData.bio}</h2>
                )}
                <div class="author-meta">
                    {authorData.location && (
                        <div class="author-location">{authorData.location} <span class="bull">&bull;</span></div>
                    )}
                    <div class="author-stats">
                        {statsText} <span class="bull">&bull;</span>
                    </div>
                    {authorData.url && (
                        <a class="social-link social-link-wb" href={authorData.url_full || authorData.url} target="_blank" rel="noopener" aria-label="Website">
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" style="width:16px;height:16px;fill:none;stroke:currentColor;stroke-width:2;stroke-linecap:round;stroke-linejoin:round;"><circle cx="12" cy="12" r="10"></circle><line x1="2" y1="12" x2="22" y2="12"></line><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path></svg>
                        </a>
                    )}
                    {authorData.twitter && (
                        <a class="social-link social-link-tw" href={`https://twitter.com/${authorData.twitter}`} target="_blank" rel="noopener" aria-label="Twitter">
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 32 32" style="width:16px;height:16px;fill:currentColor;"><path d="M30.063 7.313c-.813 1.125-1.75 2.125-2.875 2.938v.75c0 1.563-.188 3.125-.688 4.625a15.088 15.088 0 0 1-2.063 4.438c-.875 1.438-2 2.688-3.25 3.813a15.015 15.015 0 0 1-4.625 2.563c-1.813.688-3.75 1-5.75 1-3.25 0-6.188-.875-8.875-2.625.438.063.875.125 1.375.125 2.688 0 5.063-.875 7.188-2.5-1.25 0-2.375-.375-3.375-1.125s-1.688-1.688-2.063-2.875c.438.063.813.125 1.125.125.5 0 1-.063 1.5-.25-1.313-.25-2.438-.938-3.313-1.938a5.673 5.673 0 0 1-1.313-3.688v-.063c.813.438 1.688.688 2.625.688a5.228 5.228 0 0 1-1.875-2c-.5-.875-.688-1.813-.688-2.75 0-1.063.25-2.063.75-2.938 1.438 1.75 3.188 3.188 5.25 4.25s4.313 1.688 6.688 1.813a5.579 5.579 0 0 1 1.5-5.438c1.125-1.125 2.5-1.688 4.125-1.688s3.063.625 4.188 1.813a11.48 11.48 0 0 0 3.688-1.375c-.438 1.375-1.313 2.438-2.563 3.188 1.125-.125 2.188-.438 3.313-.875z"/></svg>
                        </a>
                    )}
                    {authorData.facebook && (
                        <a class="social-link social-link-fb" href={`https://facebook.com/${authorData.facebook}`} target="_blank" rel="noopener" aria-label="Facebook">
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 32 32" style="width:16px;height:16px;fill:currentColor;"><path d="M19 6h5V0h-5c-3.86 0-7 3.14-7 7v3H8v6h4v16h6V16h5l1-6h-6V7c0-.542.458-1 1-1z"/></svg>
                        </a>
                    )}
                    <a class="social-link social-link-rss" href={`https://feedly.com/i/subscription/feed/${new URL(getAssetUrl(`/author/${author}/feed.xml`), Astro.site || 'https://jekyllt.github.io/jasper2/').toString()}`} target="_blank" rel="noopener" aria-label="RSS Feed">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" style="width:16px;height:16px;fill:currentColor;"><circle cx="6.18" cy="17.82" r="2.18"/><path d="M4 4.44v2.83c7.03 0 12.73 5.7 12.73 12.73h2.83c0-8.59-6.97-15.56-15.56-15.56zm0 5.66v2.83c3.9 0 7.07 3.17 7.07 7.07h2.83c0-5.47-4.43-9.9-9.9-9.9z"/></svg>
                    </a>
                </div>
            </div>
        </div>
    </header>

    <!-- Main Content Area -->
    <main id="site-main" class="site-main outer" role="main">
        <div class="inner">
            <div class="post-feed" data-max-pages={maxPages} data-base-url={getAssetUrl(`/author/${author}/`)}>
                {page.data.map((post: any) => (
                    <PostCard post={post} />
                ))}
            </div>
        </div>
    </main>
</Layout>

<script>
  // Author Feed Infinite Scroll
  document.addEventListener('DOMContentLoaded', () => {
    const postFeed = document.querySelector('.post-feed') as HTMLElement | null;
    if (postFeed) {
      let currentPage = 1;
      const maxPages = parseInt(postFeed.getAttribute('data-max-pages') || '1', 10);
      const baseUrl = postFeed.getAttribute('data-base-url') || '/';
      let isLoading = false;
      
      const infiniteScroll = async () => {
        if (isLoading || currentPage >= maxPages) return;
        
        const threshold = 100;
        const scrollPos = window.scrollY + window.innerHeight;
        const documentHeight = document.documentElement.scrollHeight;
        
        if (scrollPos >= documentHeight - threshold) {
          isLoading = true;
          currentPage++;
          
          try {
            const nextPageUrl = `${baseUrl}page${currentPage}/`;
            const res = await fetch(nextPageUrl);
            if (!res.ok) throw new Error('Failed to fetch next author page');
            
            const html = await res.text();
            const parser = new DOMParser();
            const doc = parser.parseFromString(html, 'text/html');
            
            const newPosts = doc.querySelectorAll('.post-feed .post-card');
            newPosts.forEach((post) => {
              const el = post as HTMLElement;
              el.style.opacity = '0';
              postFeed.appendChild(el);
              setTimeout(() => {
                el.style.transition = 'opacity 0.3s ease';
                el.style.opacity = '1';
              }, 50);
            });
          } catch (err) {
            console.error('Error loading author page:', err);
            currentPage = maxPages;
          } finally {
            isLoading = false;
          }
        }
      };
      
      window.addEventListener('scroll', infiniteScroll, { passive: true });
      window.addEventListener('resize', infiniteScroll, { passive: true });
    }
  });
</script>
