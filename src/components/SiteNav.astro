---
import Navigation from './Navigation.astro';
import { SITE_CONFIG, getAssetUrl } from '../config';
import Facebook from './icons/Facebook.astro';
import Twitter from './icons/Twitter.astro';

interface Props {
  current?: string;
}

const { current } = Astro.props;
const showLogo = current !== 'home';
---

<nav class="site-nav">
    <div class="site-nav-left">
        {showLogo && (
            SITE_CONFIG.logo ? (
                <a class="site-nav-logo" href={getAssetUrl('/')}>
                    <img src={getAssetUrl(SITE_CONFIG.logo)} alt={SITE_CONFIG.title} />
                </a>
            ) : (
                <a class="site-nav-logo" href={getAssetUrl('/')}>{SITE_CONFIG.title}</a>
            )
        )}
        {SITE_CONFIG.navigation && <Navigation />}
    </div>
    <div class="site-nav-right">
        <div class="social-links">
            {SITE_CONFIG.facebook && (
                <a class="social-link social-link-fb" href={`https://facebook.com/${SITE_CONFIG.facebook}`} target="_blank" rel="noopener" aria-label="Facebook">
                    <Facebook />
                </a>
            )}
            {SITE_CONFIG.twitter && (
                <a class="social-link social-link-tw" href={`https://twitter.com/${SITE_CONFIG.twitter}`} target="_blank" rel="noopener" aria-label="Twitter">
                    <Twitter />
                </a>
            )}
        </div>
        {SITE_CONFIG.subscribers && (
            <a class="subscribe-button" href="#subscribe">Subscribe</a>
        )}
    </div>
</nav>
