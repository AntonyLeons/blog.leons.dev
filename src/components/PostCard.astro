---
import type { CollectionEntry } from 'astro:content';
import { getAssetUrl, getExcerpt, getReadingTime } from '../config';
import authors from '../data/authors.json';

interface Props {
  post: CollectionEntry<'posts'>;
  indexClass?: string;
}

const { post, indexClass = '' } = Astro.props;
const { title, cover, tags, author, description } = post.data;

// Resolve author
const authorKey = author as keyof typeof authors;
const authorData = authorKey in authors ? authors[authorKey] : null;

// Generate links
const postLink = getAssetUrl(`/${post.slug}/`);
const authorLink = getAssetUrl(`/author/${author}/`);

// Calculate reading time & excerpt
const readingTime = getReadingTime(post.body || '');
const excerpt = description || getExcerpt(post.body || '');

// Capitalize tag helper
const capitalize = (str: string) => str.charAt(0).toUpperCase() + str.slice(1);
---

<article class={`post-card ${indexClass} ${!cover ? 'no-image' : ''}`}>
    {cover && (
        <a class="post-card-image-link" href={postLink}>
            <div class="post-card-image" style={`background-image: url(${getAssetUrl(cover)})`}></div>
        </a>
    )}
    <div class="post-card-content">
        <a class="post-card-content-link" href={postLink}>
            <header class="post-card-header">
                {tags && tags.length > 0 && tags.map(tag => (
                    <span class="post-card-tags">{capitalize(tag)}</span>
                ))}
                <h2 class="post-card-title">{title}</h2>
            </header>
            <section class="post-card-excerpt">
                <p>{excerpt}</p>
            </section>
        </a>
        <footer class="post-card-meta">
            {authorData && (
                <>
                    {authorData.picture && (
                        <img class="author-profile-image" src={getAssetUrl(authorData.picture)} alt={authorData.name} />
                    )}
                    <span class="post-card-author">
                        <a href={authorLink}>{authorData.name}</a>
                    </span>
                </>
            )}
            <span class="reading-time">{readingTime}</span>
        </footer>
    </div>
</article>
